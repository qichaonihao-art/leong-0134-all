PORT=3000
HOST=0.0.0.0

# 允许访问代理的前端域名。
# 本地调试可用 *，正式上线建议填你的 Vercel 域名或自定义域名。
CORS_ALLOW_ORIGIN=https://your-vercel-domain.vercel.app

# 阿里云代理密钥。配置后，前端可不再传 apiKey。
ALIYUN_API_KEY=

# 火山引擎代理密钥。配置后，前端可不再传 appKey / accessKey。
VOLCENGINE_APP_KEY=
VOLCENGINE_ACCESS_KEY=

# 如果你的火山流程固定使用同一个 speaker_id，也可以放到服务端。
# 如果留空，前端仍可继续传入当前选择的 speaker_id。
VOLCENGINE_SPEAKER_ID=
